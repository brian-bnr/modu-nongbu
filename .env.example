# Supabase: use the "Transaction" pooled connection string (port 6543) for DATABASE_URL
# and the "Session"/direct connection string (port 5432) for DIRECT_URL.
# Project Settings > Database > Connection string in the Supabase dashboard.
DATABASE_URL="postgresql://postgres:[PASSWORD]@[HOST]:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres:[PASSWORD]@[HOST]:5432/postgres"

# NextAuth
AUTH_SECRET="replace-with-a-random-32-byte-secret"

# Seed script uses these to create the initial admin account
ADMIN_EMAIL="admin@example.com"
ADMIN_PASSWORD="change-me"

# Social login (Google / Kakao / Naver)
# Redirect URI to register in each provider's console:
#   https://www.mdfarm.co.kr/api/auth/callback/google
#   https://www.mdfarm.co.kr/api/auth/callback/kakao
#   https://www.mdfarm.co.kr/api/auth/callback/naver
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
KAKAO_CLIENT_ID=""
KAKAO_CLIENT_SECRET=""
NAVER_CLIENT_ID=""
NAVER_CLIENT_SECRET=""
